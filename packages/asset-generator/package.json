    "ioredis": "^5.10.1",
    "openai": "^6.37.0",
    "sharp": "^0.34.5",
    "axios": "^1.16.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3",
    "nanoid": "^5.1.11",
    "p-queue": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0-dev.20241222",
    "vitest": "^1.6.1",
    "@vitest/coverage-v8": "^1.6.1"
  }
