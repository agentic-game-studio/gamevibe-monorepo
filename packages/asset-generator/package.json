    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "ioredis": "^5.4.2",
    "openai": "^4.77.3",
    "sharp": "^0.33.5",
    "axios": "^1.6.7",
    "pino": "^9.5.0",
    "zod": "^3.24.1",
    "nanoid": "^5.1.5",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0-dev.20241222",
    "vitest": "^1.6.1",
    "@vitest/coverage-v8": "^1.6.1"
