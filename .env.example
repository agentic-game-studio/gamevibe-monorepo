# Discord Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_PUBLIC_KEY=your_public_key_here
DEVELOPMENT_GUILD_ID=your_test_guild_id

# Web Runtime Configuration (Required for Discord Activities)
WEB_RUNTIME_URL=http://localhost:3001
APP_URL=http://localhost:3000

# Multiplayer Server Configuration
MULTIPLAYER_PORT=2567
MULTIPLAYER_URL=ws://localhost:2567
JWT_SECRET=your_jwt_secret_here

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
REDIS_URL=redis://localhost:6379

# AI Services
MINIMAX_API_KEY=your_minimax_api_key

# Stripe Configuration (Required for Subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Stripe Price IDs (from Stripe Dashboard)
# Starter: $9.99/month, Pro: $29.99/month, Enterprise: $99.99/month
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# Storage (S3/R2) - Optional
S3_BUCKET=gamevibe-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
S3_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com
CDN_URL=https://cdn.gamevibe.ai

# Asset Generation Configuration
ENABLE_ASSET_GENERATION=false
USE_MOCK_ASSETS=true
ASSETS_BUCKET=gamevibe-assets
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
POSTHOG_API_KEY=your_posthog_key_here
MONITORING_PORT=8080
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Feature Flags
ENABLE_VOICE_CONTROLS=true
ENABLE_PREMIUM_FEATURES=true
MAX_FREE_GAMES_PER_MONTH=3

# Bot Listing Configuration (Optional)
# Top.gg (Discord Bot List)
TOPGG_TOKEN=your_topgg_api_token
TOPGG_WEBHOOK_SECRET=your_topgg_webhook_secret

# Discord.bots.gg
DISCORD_BOTS_GG_TOKEN=your_discord_bots_gg_token
DISCORD_BOTS_GG_WEBHOOK_SECRET=your_webhook_secret

# Discordbotlist.com
DISCORD_BOT_LIST_TOKEN=your_discordbotlist_token

# Social Media Integration (Optional)
# Twitter/X API v2
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# TikTok for Developers
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://your-domain.com/auth/tiktok

# Instagram Basic Display API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Environment
NODE_ENV=development
LOG_LEVEL=debug